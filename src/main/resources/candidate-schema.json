{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "type": "object",

  "required": [
    "candidateId",
    "fullName"
  ],

  "properties": {

    "candidateId": {
      "type": "string"
    },

    "fullName": {
      "type": "string"
    },

    "primaryEmail": {
      "type": [
        "string",
        "null"
      ]
    },

    "primaryPhone": {
      "type": [
        "string",
        "null"
      ]
    },

    "skills": {
      "type": "array"
    },

    "experience": {
      "type": "array"
    },

    "education": {
      "type": "array"
    },

    "overall_confidence": {
      "type": [
        "number",
        "null"
      ]
    },

    "provenance": {
      "type": [
        "array",
        "null"
      ]
    }

  }
}